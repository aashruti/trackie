# Copy to .env.local for local dev; set the same keys in the Vercel dashboard for prod.

# --- Database (required) ---
# Local dev: your Postgres.app instance.
#   postgres://USER@localhost:5432/trackie
# Production (Neon): use the POOLED connection string (host ends in -pooler.neon.tech)
# and keep sslmode=require.
#   postgres://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/trackie?sslmode=require
DATABASE_URL=

# --- Auth.js v5 (required) ---
# Generate with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET=

# --- Canonical app origin for emailed links (verification, etc.) ---
# SECURITY: links in emails must NOT trust the request Host header. On Vercel the
# platform-set VERCEL_PROJECT_PRODUCTION_URL is used automatically; set APP_URL
# only to override (e.g. a custom domain). Locally it falls back to the request host.
# APP_URL=https://trackie-aashruti.vercel.app

# --- Email (Azure Communication Services) ---
# RG datagami-trackie · ACS `trackie-acs` + Email `trackie-email` (Azure-managed domain).
# Get with: az communication list-key --name trackie-acs --resource-group datagami-trackie --query primaryConnectionString -o tsv
# Falls back to logging (no send) when unset. Add BOTH keys to the Vercel project for prod.
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=DoNotReply@<azure-managed-domain>.azurecomm.net

# --- Storage (Azure Blob) ---
# RG datagami-trackie · storage account `datagamitrackie`, container `attendance-files`.
# Get with: az storage account show-connection-string --name datagamitrackie --resource-group datagami-trackie -o tsv
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attendance-files

# --- First admin bootstrap (used by `npm run create-admin`, not by the app) ---
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME="Super Admin"
